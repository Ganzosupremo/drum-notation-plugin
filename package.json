{
        "name": "drum-notation-plugin",
        "version": "0.0.1",
        "description": "This is a sample plugin for Obsidian (https://obsidian.md)",
        "main": "main.js",
        "type": "module",
        "scripts": {
                "dev": "node esbuild.config.mjs",
                "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
                "version": "node version-bump.mjs && git add manifest.json versions.json",
                "lint": "eslint .",
                "test": "node --import tsx/esm --test src/parser.test.ts src/renderer/notes/renderHiHatNote.test.ts"
        },
        "keywords": [],
        "license": "0-BSD",
        "devDependencies": {
                "@types/node": "^20.19.40",
                "builtin-modules": "^3.3.0",
                "esbuild": "^0.20.2",
                "obsidian": "latest",
                "tslib": "^2.6.2",
                "tsx": "^4.21.0",
                "typescript": "^5.4.3"
        },
        "dependencies": {
                "obsidian": "latest"
        }
}
